# Server
SITEFORGE_HOST=127.0.0.1
SITEFORGE_PORT=8787
SITEFORGE_ACCESS_TOKEN=replace-with-a-long-random-value
SITEFORGE_DATA_DIR=/var/lib/site-forge/data
SITEFORGE_WORKSPACE_DIR=/var/lib/site-forge/workspaces
SITEFORGE_MAX_CONCURRENT=1
SITEFORGE_COMMAND_TIMEOUT_MS=900000

# Codex. The SDK reads CODEX_API_KEY. OPENAI_API_KEY is accepted as a fallback.
CODEX_API_KEY=
OPENAI_API_KEY=
SITEFORGE_CODEX_MODEL=

# GitHub personal access token. It must be able to create repositories and push contents.
GITHUB_TOKEN=
GITHUB_OWNER=
# Set to org only when GITHUB_OWNER is an organization.
GITHUB_OWNER_TYPE=user
GITHUB_DEFAULT_PRIVATE=true

# Vercel access token. VERCEL_TEAM_ID is optional for a personal account.
VERCEL_TOKEN=
VERCEL_TEAM_ID=
